/target
# rsfai-py is a standalone (workspace-excluded) crate built by maturin, so it
# has its own nested build directory the root /target rule does not cover.
/crates/rsfai-py/target
**/*.rs.bk
Cargo.lock.orig

# Python build artifacts from maturin / rsfai-py
__pycache__/
*.pyc
*.so
.venv/

# Golden datasets: per-pixel arrays (image, mask, positions, corners, preproc,
# corrections, CSR matrix) are large (~100 MB/config) and fully regenerable by
# golden/gen_golden.py (deterministic under OMP_NUM_THREADS=1). We commit only
# the small golden OUTPUT curves (out_*.npy, KB each), the manifest, and the
# .poni, so the repo stays lean. Regenerate the rest locally; git-LFS is the
# eventual home once a remote is configured (see golden/README.md).
golden/datasets/**/*.npy
!golden/datasets/**/out_*.npy
golden/datasets/**/*.edf
golden/datasets/**/*.cbf
golden/datasets/**/*.h5
# Same convention for the MultiGeometry (M9.1) and Corrections (M9.0) golden
# trees: regenerate the per-pixel inputs (images, mask, flat, ...) via
# golden/gen_golden_multigeometry.py / gen_golden_corrections.py; commit only the
# out_*.npy curves, the manifests, the .poni, and inputs.json (not an .npy).
golden/datasets_multigeometry/**/*.npy
!golden/datasets_multigeometry/**/out_*.npy
golden/datasets_corrections/**/*.npy
!golden/datasets_corrections/**/out_*.npy
# Fiber/GI golden (M10.0 unit arrays, M10.1 FiberIntegrator): regenerate the
# per-pixel inputs via golden/gen_golden_fiber.py / gen_golden_fiber_integrator.py.
# datasets_fiber outputs use the out_*.npy naming (commit them, ignore the
# sample_*.npy position inputs); datasets_fiber_integrator commits its small
# integration-result arrays + .poni + manifest and ignores only the large input
# image (data.npy).
golden/datasets_fiber/**/*.npy
!golden/datasets_fiber/**/out_*.npy
golden/datasets_fiber_integrator/data.npy
# Calibrant golden (M12 Calibrant + crystallography): every output here is small
# (per-calibrant d-spacing / 2theta / peak arrays are <= 59 doubles, the .D files
# a few KB) and offline-required, so we COMMIT the .npy arrays, the copied .D
# d-spacing files, and the manifest. Only ignore detector-image / archive blobs
# that have no business in this tree (none are generated today; the rule is
# defensive against an accidental large drop).
golden/datasets_calibrant/**/*.edf
golden/datasets_calibrant/**/*.cbf
golden/datasets_calibrant/**/*.h5
